<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}SymfoConnect
			{% endblock %}
		</title>
		<style>
			nav {
				background: #2563eb;
				color: #fff;
				padding: 1em 2em;
				display: flex;
				gap: 2em;
				align-items: center;
				box-shadow: 0 2px 8px rgba(37, 99, 235, 0.08);
			}
			nav a {
				color: #fff;
				text-decoration: none;
				font-weight: 600;
				letter-spacing: 0.5px;
				transition: color 0.2s;
			}
			nav a:hover {
				color: #a5b4fc;
			}
			.container {
				max-width: 700px;
				margin: 2em auto;
				background: #fff;
				border-radius: 12px;
				box-shadow: 0 2px 16px rgba(37, 99, 235, 0.10);
				padding: 2em 2.5em;
			}
			.flash {
				background: #e6fffa;
				border: 1px solid #b2f5ea;
				color: #234e52;
				padding: 0.75em 1.2em;
				border-radius: 6px;
				margin-bottom: 1.5em;
				font-size: 1em;
				box-shadow: 0 1px 4px rgba(37, 99, 235, 0.06);
			}
			.post-card {
				background: #f1f5ff;
				border: 1px solid #dbeafe;
				border-radius: 10px;
				box-shadow: 0 2px 8px rgba(37, 99, 235, 0.07);
				padding: 1.2em 1.5em;
				margin-bottom: 2em;
				transition: box-shadow 0.2s;
			}
			.post-card:hover {
				box-shadow: 0 4px 16px rgba(37, 99, 235, 0.13);
			}
			.post-meta {
				font-size: 0.95em;
				color: #2563eb;
				margin-bottom: 0.5em;
				font-weight: 600;
			}
			.post-content {
				font-size: 1.13em;
				color: #222;
				margin-bottom: 0.2em;
			}
			@media(max-width: 800px) {
				.container {
					padding: 1em;
				}
				nav {
					flex-direction: column;
					gap: 1em;
					align-items: flex-start;
				}
			}
		</style>
		{% block stylesheets %}{% endblock %}
		{% block javascripts %}{% endblock %}
		{% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
		{% if frankenphpHotReload %}
			<meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
			<script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
			<script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
		{% endif %}
	</head>
	<body>
		<nav>
			<a href="{{ path('app_home') }}">Accueil</a>
            <a href="{{ path('app_feed') }}">Feed</a>
			<a href="{{ path('post_new') }}">Nouveau post</a>
            <a href="{{ path('app_notifications') }}">Notifications</a>


            {% if app.user %}
                <a href="{{ path('app_profile', {'username': app.user.username}) }}">Profil</a>
            {% endif %}



			
            {% if app.user %}
                <span style="margin-left:auto;">Connecté en tant que {{ app.user.username }}</span>
                <a href="{{ path('app_logout') }}" style="margin-left:1em;background:#e53e3e;padding:0.5em 1em;border-radius:6px;color:#fff;font-weight:600;transition:background 0.2s;">Logout</a>
            {% else %}
                <a href="{{ path('app_login') }}" style="margin-left:auto;background:#2563eb;padding:0.5em 1em;border-radius:6px;color:#fff;font-weight:600;transition:background 0.2s;">Login</a>
            {% endif %}
		</nav>
		<div class="container">
			{% for label, messages in app.flashes %}
				{% for message in messages %}
					<div class="flash">{{ message }}</div>
				{% endfor %}
			{% endfor %}
			{% block body %}{% endblock %}
		</div>
	</body>
</html>
