{% extends 'base.html.twig' %}

{% block title %}Accueil - SymfoConnect
{% endblock %}

{% block body %}
	<h1>Derniers posts</h1>
	<div>
		{% for post in posts %}
			<div class="post-card">
				<div class="post-meta">
					{{ post.author.username }}
					—
					{{ post.createdAt ? post.createdAt|date('d/m/Y H:i') : 'Date inconnue' }}
				</div>
				<div class="post-content">
					{{ post.content|e }}
				</div>
			</div>
		{% else %}
			<div>Aucun post pour le moment.</div>
		{% endfor %}
	</div>
{% endblock %}
