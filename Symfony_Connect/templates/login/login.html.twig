{% extends 'base.html.twig' %}

{% block title %}Connexion
{% endblock %}

{% block body %}

	<div style="max-width: 420px; margin: 60px auto; padding: 30px; background: #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">

		<h1 style="text-align:center; margin-bottom: 25px;">Connexion</h1>

		{% if error %}
			<div style="background:#ffe5e5;color:#b00020;padding:10px;border-radius:6px;margin-bottom:15px;">
				{{ error.messageKey|trans(error.messageData, 'security') }}
			</div>
		{% endif %}

		{% if app.user %}
			<div style="margin-bottom:15px; color:#2563eb;">
				Connecté en tant que
				{{ app.user.userIdentifier }}
				<a href="{{ logout_path() }}" style="color:red; margin-left:10px;">Logout</a>
			</div>
		{% endif %}

		<form method="post">

			<label>Email</label>
			<input type="email" name="email" value="{{ last_username }}" required style="width:100%; padding:10px; margin:8px 0 15px; border:1px solid #ddd; border-radius:6px;">

			<label>Mot de passe</label>
			<input type="password" name="password" required style="width:100%; padding:10px; margin:8px 0 20px; border:1px solid #ddd; border-radius:6px;">

			<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

			<button type="submit" style="width:100%; padding:10px; background:#2563eb; color:white; border:none; border-radius:6px; font-weight:bold; cursor:pointer;">
				Se connecter
			</button>

			<a href="{{ path('app_register') }}" style="display:block; text-align:center; margin-top:15px; color:#2563eb; text-decoration:none;">
				Créer un compte
			</a>

		</form>

	</div>

{% endblock %}
