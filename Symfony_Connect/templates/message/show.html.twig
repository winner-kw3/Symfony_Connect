{% extends 'base.html.twig' %}

{% block body %}

	{% set otherUser = conversation.user1 == app.user ? conversation.user2 : conversation.user1 %}

	<div
		style="max-width:700px; margin:auto;">

		<!-- HEADER -->
		<div style="padding:15px; border-bottom:1px solid #eee; margin-bottom:10px;">
			<strong>{{ otherUser.username }}</strong>
		</div>

		<!-- MESSAGES -->
		<div style="height:60vh; overflow-y:auto; padding:10px; display:flex; flex-direction:column; gap:8px;">

			{% for m in conversation.messages %}

				<div style="display:flex; justify-content:{{ m.sender == app.user ? 'flex-end' : 'flex-start' }};">

					<div style="max-width:70%;
							                            padding:10px 12px;
							                            border-radius:15px;
							                            background:{{ m.sender == app.user ? '#2563eb' : '#f1f1f1' }};
							                            color:{{ m.sender == app.user ? 'white' : 'black' }};">

						<div>
							{{ m.content }}
						</div>

						<div style="font-size:0.75em; margin-top:4px; opacity:0.7; display:flex; justify-content:space-between;">

							<span>{{ m.createdAt|date('H:i') }}</span>

							{% if m.sender == app.user %}

								{% if m.isRead %}
									<span>✓✓ lu</span>
								{% else %}
									<span>✓ envoyé</span>
								{% endif %}

							{% endif %}

						</div>

					</div>

				</div>

			{% endfor %}

		</div>

		<!-- INPUT -->
		<form method="post" action="{{ path('app_message_send', {id: conversation.id}) }}" style="display:flex; gap:10px; padding:10px; border-top:1px solid #eee;">

			<input type="text" name="content" placeholder="Écrire un message..." style="flex:1; padding:10px; border:1px solid #ddd; border-radius:20px;">

			<button style="background:#2563eb; color:white; border:none; padding:10px 15px; border-radius:20px;">
				Envoyer
			</button>

		</form>

	</div>

{% endblock %}
