{% extends 'base.html.twig' %}

{% block title %}Profil de
	{{ user.username }}
{% endblock %}

{% block body %}

	<div
		style="max-width:700px; margin:40px auto;">

		<!-- HEADER PROFIL -->
		<div style="display:flex; align-items:center; gap:20px; margin-bottom:25px;">

			{% if user.avatarUrl %}
				<img src="{{ user.avatarUrl }}" alt="Avatar" style="width:80px; height:80px; border-radius:50%; object-fit:cover;">
			{% else %}
				<div style="
						                width:80px;
						                height:80px;
						                border-radius:50%;
						                background:#e5e7eb;
						                display:flex;
						                align-items:center;
						                justify-content:center;
						            ">
					<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="#9ca3af" viewbox="0 0 24 24">
						<path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v3h20v-3c0-3.3-6.7-5-10-5z"/>
					</svg>
				</div>
			{% endif %}

			<div style="flex:1;">
				<h2 style="margin:0;">{{ user.username }}</h2>

				<div style="margin-top:8px; color:#555;">
					<strong>{{ user.followersCount }}</strong>
					followers
					                •
					<strong>{{ user.followingCount }}</strong>
					suivis
				</div>
			</div>

			<!-- BOUTON FOLLOW -->
			{% if app.user and not isOwner %}

				{% if isFollowing %}
					<form method="post" action="{{ path('user_unfollow', { username: user.username }) }}">
						<input type="hidden" name="_token" value="{{ csrf_token('unfollow' ~ user.id) }}">
						<button style="padding:8px 14px; border:none; background:#e53e3e; color:#fff; border-radius:6px; cursor:pointer;">
							Ne plus suivre
						</button>
                        <a href="{{ path('app_message_new', {username: user.username}) }}">
                            Envoyer un message
                        </a>

					</form>
				{% else %}
					<form method="post" action="{{ path('user_follow', { username: user.username }) }}">
						<input type="hidden" name="_token" value="{{ csrf_token('follow' ~ user.id) }}">
						<button style="padding:8px 14px; border:none; background:#2563eb; color:#fff; border-radius:6px; cursor:pointer;">
							Suivre
						</button>
					</form>
				{% endif %}

			{% endif %}
		</div>

		<!-- BIO -->
		<div style="margin-bottom:30px; color:#444;">
			<strong>Bio :</strong><br>
			{{ user.bio ?: 'Non renseignée' }}
		</div>

		<!-- BOUTON EDIT -->
		{% if isOwner %}
			<a href="#" style="display:inline-block; margin-bottom:25px; color:#2563eb;">
				Modifier mon profil
			</a>
		{% endif %}

		<!-- POSTS -->
		<h3 style="margin-bottom:15px;">Posts</h3>

		{% for post in posts %}
			<div style="background:#fff; border:1px solid #eee; border-radius:10px; padding:15px; margin-bottom:15px; box-shadow:0 2px 6px rgba(0,0,0,0.05);">

				<div style="font-size:0.9em; color:#666; margin-bottom:8px;">
					{{ post.createdAt ? post.createdAt|date('d/m/Y H:i') : 'Date inconnue' }}
				</div>

				<div style="font-size:1.1em; margin-bottom:10px;">
					{{ post.content|e }}
				</div>

				{% if is_granted('POST_DELETE', post) %}
					<form method="post" action="{{ path('post_delete', { id: post.id }) }}" onsubmit="return confirm('Supprimer ce post ?');">

						<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">

						<button
							style="
								                        background:none;
								                        border:none;
								                        color:#e53e3e;
								                        cursor:pointer;
								                        display:flex;
								                        align-items:center;
								                        gap:6px;
								                    ">

							<!-- ICON DELETE -->
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewbox="0 0 24 24">
								<path d="M6 7h12l-1 14H7L6 7zm3-3h6l1 2H8l1-2z"/>
							</svg>

							Supprimer
						</button>

					</form>
				{% endif %}

			</div>
		{% else %}
			<div style="color:#777;">Aucun post pour ce profil.</div>
		{% endfor %}

	</div>

{% endblock %}
