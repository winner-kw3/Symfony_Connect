{% extends 'base.html.twig' %}

{% block title %}Profil de
	{{ user.username }}
	- SymfoConnect
{% endblock %}

{% block body %}
	<h1>Profil de
		{{ user.username }}</h1>
	{% if user.avatarUrl %}
		<img src="{{ user.avatarUrl }}" alt="Avatar" style="max-width:100px;max-height:100px;">
	{% endif %}
	<p>
		<strong>Bio :</strong>
		{{ user.bio ? user.bio : 'Non renseignée' }}</p>
	<h2>Ses posts</h2>
	<div>
		{% for post in posts %}
			<div class="post-card">
				<div class="post-meta">
					{{ post.createdAt ? post.createdAt|date('d/m/Y H:i') : 'Date inconnue' }}
				</div>
				<div class="post-content">
					{{ post.content|e }}
				</div>
			</div>
		{% else %}
			<div>Aucun post pour ce profil.</div>
		{% endfor %}
	</div>
{% endblock %}
