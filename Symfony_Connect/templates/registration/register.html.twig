{% extends 'base.html.twig' %}

{% block title %}Inscription
{% endblock %}

{% block body %}

	<div style="max-width:420px; margin:60px auto; padding:30px; background:#fff; border-radius:12px; box-shadow:0 4px 20px rgba(0,0,0,0.08);">

		<h1 style="text-align:center; margin-bottom:25px;">Créer un compte</h1>

		{{ form_errors(registrationForm) }}

		{{ form_start(registrationForm) }}

		<div style="margin-bottom:15px;">
			<label>Email</label>
			{{ form_widget(registrationForm.email, {
                'attr': {
                    'placeholder': 'ex: email@gmail.com',
                    'style': 'width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; margin-top:6px;'
                }
            }) }}
			{{ form_errors(registrationForm.email) }}
		</div>

		<div style="margin-bottom:15px;">
			<label>Nom d’utilisateur</label>
			{{ form_widget(registrationForm.username, {
                'attr': {
                    'placeholder': 'Ton pseudo',
                    'style': 'width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; margin-top:6px;'
                }
            }) }}
			{{ form_errors(registrationForm.username) }}
		</div>

		<div style="margin-bottom:15px;">
			<label>Mot de passe</label>
			{{ form_widget(registrationForm.plainPassword, {
                'attr': {
                    'placeholder': '••••••••',
                    'style': 'width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; margin-top:6px;'
                }
            }) }}
			{{ form_errors(registrationForm.plainPassword) }}
		</div>

		<div style="margin-bottom:20px;">
			{{ form_widget(registrationForm.agreeTerms) }}
			<label>J’accepte les conditions</label>
			{{ form_errors(registrationForm.agreeTerms) }}
		</div>

		<button type="submit" style="width:100%; padding:10px; background:#2563eb; color:#fff; border:none; border-radius:6px; font-weight:bold; cursor:pointer;">
			S’inscrire
		</button>

		{{ form_end(registrationForm) }}

		<p style="text-align:center; margin-top:15px;">
			Déjà un compte ?
			<a href="{{ path('app_login') }}" style="color:#2563eb;">Connexion</a>
		</p>

	</div>

{% endblock %}
